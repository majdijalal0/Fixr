# ====================================================================
# Fixr - Backend Environment Variables Template
# ====================================================================

# MongoDB Connection String (Atlas URI or Local String)
MONGO_URI=mongodb+srv://<username>:<password>@cluster.mongodb.net/<dbname>?retryWrites=true&w=majority

# Port the Express server listens on (defaults to 5000)
PORT=5000

# JSON Web Token signing key (Provide a secure random string)
JWT_SECRET=your_super_secret_jwt_key_here

# Cloudinary Integration (Required for profile photos & certification uploads)
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret_key
