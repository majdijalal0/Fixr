# ====================================================================
# Fixr - Global Git Ignore
# ====================================================================

# Dependency directories
node_modules/
jspm_packages/
web_modules/

# Local Environment Variables & Secrets
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
*.env
frontend/.env
frontend/.env.local

# Build outputs and distribution directories
dist/
dist-ssr/
build/
out/
.next/
.nuxt/
.cache/

# Debug logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*
*.log

# Diagnostic reports
report.[0-9]*.[0-9]*.[0-9]*.[0-9]*.json

# OS-specific files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# IDE and Editor directories/files
.vscode/*
!.vscode/extensions.json
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
*.swo
*.swn
*~

# Temporary files
tmp/
temp/
